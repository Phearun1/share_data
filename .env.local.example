# Copy to .env.local for local dev, and set the same values in Netlify's
# Environment variables (Site configuration -> Environment variables).
#
# Find these in your Supabase project: Project Settings -> API.

# Public project URL (safe to expose).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Public anon key (safe to expose — used by the browser to upload).
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Secret service-role key (SERVER ONLY — never expose in the browser).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Storage bucket name (optional; defaults to "upload").
SUPABASE_BUCKET=upload
